#!/bin/bash
# TraderAI.app 実行本体。ダブルクリックで Dock アプリとして起動。
# 初回は依存ライブラリを自動セットアップし、サーバ起動を待ってブラウザを開く。
# セットアップが失敗しても venv を作り直して自動リトライする。
# Terminal は出ない。停止は Dock アイコン右クリック →「終了」。

PORT="${TRADERAI_PORT:-8787}"

# --- リポジトリの場所を特定 ---------------------------------------
SELF_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO=""
d="$SELF_DIR"
for _ in 1 2 3 4 5 6; do
  if [ -f "$d/pyproject.toml" ]; then REPO="$d"; break; fi
  d="$(dirname "$d")"
done
if [ -z "$REPO" ] && [ -f "$HOME/TraderAI/pyproject.toml" ]; then
  REPO="$HOME/TraderAI"
fi
if [ -z "$REPO" ]; then
  osascript -e 'display alert "TraderAI" message "リポジトリが見つかりません。TraderAI.app を TraderAI フォルダ内に置くか、~/TraderAI に配置してください。"' >/dev/null 2>&1
  exit 1
fi
cd "$REPO" || exit 1

LOG="/tmp/traderai_setup.log"

deps_ok() { "$1" -c "import pandas, yfinance, anthropic" >/dev/null 2>&1; }

# 依存ライブラリを 1 つの venv にインストール。成功すれば 0。
install_into() {
  local py="$1"
  "$py" -m pip install --upgrade pip setuptools wheel >>"$LOG" 2>&1
  "$py" -m pip install -e "$REPO" >>"$LOG" 2>&1
  deps_ok "$py"
}

PY="$REPO/.venv/bin/python"

if ! [ -x "$PY" ] || ! deps_ok "$PY"; then
  osascript -e 'display notification "初期セットアップ中… 数分かかる場合があります" with title "TraderAI"' >/dev/null 2>&1
  : >"$LOG"

  # 1) 既存 venv があればそのままインストールを試す
  if [ -x "$PY" ]; then
    echo "=== try existing venv ===" >>"$LOG"
    install_into "$PY"
  fi

  # 2) ダメなら venv を作り直して再挑戦(壊れた venv の自己修復)
  if ! deps_ok "$PY"; then
    echo "=== recreate venv ===" >>"$LOG"
    rm -rf "$REPO/.venv"
    python3 -m venv "$REPO/.venv" >>"$LOG" 2>&1
    PY="$REPO/.venv/bin/python"
    [ -x "$PY" ] && install_into "$PY"
  fi

  # 3) それでもダメなら、ログ末尾を添えて失敗を通知
  if ! deps_ok "$PY"; then
    TAIL="$(tail -n 12 "$LOG" 2>/dev/null | sed 's/"/\\"/g')"
    osascript -e "display alert \"TraderAI セットアップ失敗\" message \"依存ライブラリのインストールに失敗しました。下記エラーを確認してください(全文: $LOG)。\n\n$TAIL\"" >/dev/null 2>&1
    exit 1
  fi
fi

# 初回のみ:将来予測に使う毎月の積立額を GUI で尋ねて保存(ターミナル不要)。
if ! "$PY" -m traderai.cli config 2>/dev/null | grep -q "monthly_contribution"; then
  AMT=$(osascript -e 'set r to text returned of (display dialog "毎月の積立額(円)を入力してください。\n将来予測グラフに使います(後で変更可・0でもOK)。" default answer "0" with title "TraderAI 初期設定")' 2>/dev/null)
  if [ -n "$AMT" ]; then
    "$PY" -m traderai.cli config --monthly "$AMT" >/dev/null 2>&1
  fi
fi

# 起動のたびに純資産スナップショットを記録(推移グラフ用、失敗は無視)。
"$PY" -m traderai.cli journal snapshot --note auto >/dev/null 2>&1

# サーバが応答してからブラウザを開く(初回セットアップの遅延に対応)。
( for _ in $(seq 1 90); do
    if curl -s "http://127.0.0.1:${PORT}/data" >/dev/null 2>&1; then
      open "http://127.0.0.1:${PORT}"; break
    fi
    sleep 1
  done ) >/dev/null 2>&1 &

# サーバを前面実行(プロセスが生きている間 .app は起動状態)。
exec "$PY" -m traderai.cli serve --host 127.0.0.1 --port "$PORT"
